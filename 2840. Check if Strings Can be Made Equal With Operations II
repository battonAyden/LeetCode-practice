class Solution {
    public boolean checkStrings(String s1, String s2) {
        char b = s2.charAt(s2.length()-1);
        for (int i = 0; i < 3; i++) {
            char a = s1.charAt(i);
            if ((s2.length() - a) % 2 == 0) {
                s1 = s2.replace(b,a);
            }
        }
         return s1.equals(s2);
}
}
